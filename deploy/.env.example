# Copy to ".env" and set strong, unique values BEFORE `docker compose up -d`.
# Anyone who reaches these can hijack the stream / Icecast admin / now-playing.
ICECAST_SOURCE_PASS=change-me-source
ICECAST_ADMIN_PASS=change-me-admin
BRIDGE_TOKEN=change-me-token

# Optional:
STREAM_BITRATE=128k
SID_DURATION=180
MAX_TRACK=300
HTTP_PORT=8080
